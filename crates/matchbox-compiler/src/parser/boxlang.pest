WHITESPACE = _{ " " | "\t" | "\r" | "\n" }
COMMENT = _{ ("//" ~ (!"\n" ~ ANY)*) | ("/*" ~ (!"*/" ~ ANY)* ~ "*/") }

program = { SOI ~ statement* ~ EOI }

statement = {
    ( import_stmt
    | class_decl
    | function_decl
    | for_loop
    | if_statement
    | try_catch
    | return_stmt
    | throw_stmt
    | variable_decl
    | expression_stmt
    )
}

import_keyword = @{ "import" ~ !ASCII_ALPHANUMERIC }
import_stmt = { import_keyword ~ dotted_identifier ~ ";"? }
dotted_identifier = @{ identifier ~ ("." ~ identifier)* }

class_keyword = @{ "class" ~ !ASCII_ALPHANUMERIC }
extends_attr = { "extends" ~ "=" ~ string }
accessors_attr = { "accessors" ~ "=" ~ string }
class_attr = { extends_attr | accessors_attr }
class_decl = { class_keyword ~ identifier ~ class_attr* ~ "{" ~ class_member* ~ "}" }
class_member = { property | statement }

property_keyword = @{ "property" ~ !ASCII_ALPHANUMERIC }
property = { property_keyword ~ identifier ~ ";"? }

function_keyword = @{ "function" ~ !ASCII_ALPHANUMERIC }
access_modifier = @{ ("public" | "private") ~ !ASCII_ALPHANUMERIC }
type_name = { !keyword ~ identifier }
function_decl = { access_modifier? ~ (type_name ~ function_keyword | function_keyword) ~ identifier ~ "(" ~ params? ~ ")" ~ block }

return_keyword = @{ "return" ~ !ASCII_ALPHANUMERIC }
return_stmt = { return_keyword ~ expression? ~ ";"? }

var_keyword = @{ "var" ~ !ASCII_ALPHANUMERIC }
variable_decl = { var_keyword ~ assignment }

required_keyword = @{ "required" ~ !ASCII_ALPHANUMERIC }
param_decl = { required_keyword? ~ (type_name ~ identifier | identifier) }
params = { param_decl ~ ("," ~ param_decl)* }

for_keyword = @{ "for" ~ !ASCII_ALPHANUMERIC }
for_loop = { for_keyword ~ "(" ~ (for_in | for_classic) ~ ")" ~ block }

in_keyword = @{ "in" ~ !ASCII_ALPHANUMERIC }
for_in = { identifier ~ ("," ~ identifier)? ~ in_keyword ~ expression }
for_classic = { init? ~ ";" ~ condition? ~ ";" ~ update? }
init = { variable_decl | assignment | expression }
condition = { expression }
update = { expression }

if_keyword = @{ "if" ~ !ASCII_ALPHANUMERIC }
else_keyword = @{ "else" ~ !ASCII_ALPHANUMERIC }
if_statement = { if_keyword ~ "(" ~ expression ~ ")" ~ block ~ (else_keyword ~ block)? }
block = { "{" ~ statement* ~ "}" }

try_keyword = @{ "try" ~ !ASCII_ALPHANUMERIC }
catch_keyword = @{ "catch" ~ !ASCII_ALPHANUMERIC }
finally_keyword = @{ "finally" ~ !ASCII_ALPHANUMERIC }
try_catch = { try_keyword ~ block ~ catch_block* ~ finally_block? }
catch_block = { catch_keyword ~ "(" ~ identifier ~ ")" ~ block }
finally_block = { finally_keyword ~ block }

throw_keyword = @{ "throw" ~ !ASCII_ALPHANUMERIC }
throw_stmt = { throw_keyword ~ expression? ~ ";"? }

expression_stmt = { expression ~ ";"? }

expression = {
    assignment
    | binary_expr
}

assignment = { target ~ "=" ~ expression }
target = { atom ~ (array_access | member_access)* }

binary_expr = { primary ~ (operator ~ primary)* }

operator = { "+" | "-" | "*" | "/" | "==" | "!=" | "<=" | ">=" | "<" | ">" | "&" }

primary = { atom ~ (function_call_args | array_access | member_access | postfix_op)* }

atom = {
    new_expression
    | literal
    | !keyword ~ identifier
    | "(" ~ expression ~ ")"
}

keyword = {
    import_keyword
    | class_keyword
    | property_keyword
    | function_keyword
    | return_keyword
    | var_keyword
    | for_keyword
    | in_keyword
    | if_keyword
    | else_keyword
    | try_keyword
    | catch_keyword
    | finally_keyword
    | throw_keyword
    | new_keyword
}

new_keyword = @{ "new" ~ !ASCII_ALPHANUMERIC }
new_expression = { new_keyword ~ dotted_identifier ~ "(" ~ args? ~ ")" }

function_call_args = { "(" ~ args? ~ ")" }
array_access = { "[" ~ expression ~ "]" }
member_access = { "." ~ identifier }
postfix_op = { "++" | "--" }
prefix_op = { ("++" | "--") ~ target }

function_call = _{ identifier ~ function_call_args }
args = { expression ~ ("," ~ expression)* }

literal = { string | number | boolean | null_lit | array_literal | struct_literal | anonymous_function }

anonymous_function = {
    (function_keyword ~ "(" ~ params? ~ ")" ~ block) |
    (lambda_params ~ ("=>" | "->") ~ (block | expression))
}
lambda_params = { ("(" ~ params? ~ ")") | identifier }

array_literal = { "[" ~ (expression ~ ("," ~ expression)* ~ ","?)? ~ "]" }

struct_literal = { "{" ~ (struct_member ~ ("," ~ struct_member)* ~ ","?)? ~ "}" }
struct_member = { struct_key ~ (":" | "=") ~ expression }
struct_key = { identifier | string | number }

string = ${
    "\"" ~ string_content_double ~ "\"" |
    "'" ~ string_content_single ~ "'"
}
string_content_double = _{ (interpolation | escaped_hash | string_text_double)* }
string_content_single = _{ (interpolation | escaped_hash | string_text_single)* }

interpolation = !{ "#" ~ expression ~ "#" }
escaped_hash = @{ "##" }
string_text_double = @{ (!("\"" | "#") ~ ANY)+ }
string_text_single = @{ (!("'" | "#") ~ ANY)+ }

number = @{ "-"? ~ ASCII_DIGIT+ ~ ("." ~ ASCII_DIGIT+)? }

boolean = @{ ("true" | "false") ~ !ASCII_ALPHANUMERIC }

null_lit = @{ "null" ~ !ASCII_ALPHANUMERIC }

identifier = @{ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_")* }
