<html>
    <head>
        <title><bx:output>#viewArgs.title#</bx:output></title>
        <style>
            body {
                margin: 0;
                font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
                background: linear-gradient(135deg, #f5efe3 0%, #dbe7f0 100%);
                color: #1d2935;
            }

            main {
                max-width: 38rem;
                margin: 4rem auto;
                padding: 2rem;
                background: rgba(255, 255, 255, 0.82);
                border: 1px solid rgba(29, 41, 53, 0.12);
                border-radius: 1.25rem;
                box-shadow: 0 24px 60px rgba(29, 41, 53, 0.12);
            }

            h1 {
                margin-top: 0;
                font-size: 2.4rem;
            }

            .count {
                font-size: 4rem;
                font-weight: 700;
                margin: 1rem 0;
            }

            button {
                border: 0;
                border-radius: 999px;
                background: #136f63;
                color: white;
                padding: 0.9rem 1.4rem;
                font-size: 1rem;
                cursor: pointer;
            }

            button:disabled {
                opacity: 0.45;
                cursor: wait;
            }

            .status {
                margin-top: 1rem;
                color: #5b6875;
            }
        </style>
    </head>
    <body>
        <main>
            <p>WebSocket example</p>
            <h1><bx:output>#viewArgs.title#</bx:output></h1>
            <p>Open this page in multiple tabs. Each click increments the shared counter and broadcasts the new count to every connected client.</p>
            <div class="count" id="count">0</div>
            <button id="increment" disabled>Increment Counter</button>
            <div class="status" id="status">Connecting to websocket...</div>
        </main>

        <script>
            const countEl = document.getElementById("count");
            const statusEl = document.getElementById("status");
            const button = document.getElementById("increment");

            const scheme = window.location.protocol === "https:" ? "wss" : "ws";
            const socket = new WebSocket(`${scheme}://${window.location.host}/ws`);

            socket.addEventListener("open", () => {
                statusEl.textContent = "Connected";
                button.disabled = false;
            });

            socket.addEventListener("close", () => {
                statusEl.textContent = "Disconnected";
                button.disabled = true;
            });

            socket.addEventListener("message", (event) => {
                const payload = JSON.parse(event.data);
                if (payload.type === "count") {
                    countEl.textContent = payload.count;
                }
            });

            button.addEventListener("click", () => {
                socket.send("increment");
            });
        </script>
    </body>
</html>
