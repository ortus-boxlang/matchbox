// --- Language Features ---

// Test else if
x = 10;
if (x == 1) {
    println("fail 1");
} else if (x == 10) {
    println("else if worked");
} else {
    println("fail 2");
}

// Test operator precedence
// && has higher precedence than ||
// true || false && false  => true || (false && false) => true
if (true || false && false) {
    println("precedence 1 worked");
} else {
    println("precedence 1 failed");
}

// == has higher precedence than &&
// 1 == 1 && 2 == 2 => (1 == 1) && (2 == 2) => true
if (1 == 1 && 2 == 2) {
    println("precedence 2 worked");
}

// + and & precedence
// "a" & 1 + 1 => "a" & (1 + 1) => "a2"
if ("a" & 1 + 1 == "a2") {
    println("precedence 3 worked");
}

// Case-insensitive string comparison
if ("Latest" == "LATEST" && "latest" == "latest") {
    println("case-insensitive comparison worked");
}

// --- BIFs ---

// FS BIFs
dir = "test_integration_dir";
if (directoryExists(dir)) {
    directoryDelete(dir, true);
}
directoryCreate(dir);
if (directoryExists(dir)) {
    println("directory BIFs worked");
}

testFile = dir & "/test.txt";
fileWrite(testFile, "integration test content");
if (fileExists(testFile)) {
    content = fileRead(testFile);
    if (trim(content) == "integration test content") {
        println("file BIFs worked");
    }
}

// JSON BIFs
jsonStr = '{"a": 1, "b": [1, 2], "c": {"d": "val"}}';
data = JSONdeserialize(jsonStr);
if (data.a == 1 && data.b[2] == 2 && data.c.d == "val") {
    println("JSON BIFs worked");
}

// loadProperties
propStr = "name=matchbox
version=1.0.0
## comment";
props = loadProperties(propStr);
if (props.name == "matchbox" && props.version == "1.0.0") {
    println("loadProperties worked");
}

// Crypto BIF
// hash("abc") SHA-256 => ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad
if (hash("abc") == "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad") {
    println("hash worked");
}

// String BIFs
if (trim("  hello  ") == "hello" && indexOf("abcdef", "cd") == 3) {
    println("string BIFs worked");
}

// Cleanup
directoryDelete(dir, true);
if (!directoryExists(dir)) {
    println("cleanup worked");
}
