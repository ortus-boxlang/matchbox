// MatchBox Fluent Todo TUI App
// Run with: cargo run --features bif-tui -- tests/todo.bxs

class App {
    property todos;
    property completed;
    property selected;
    property inputMode;
    property inputChars;
    property statusMsg;
    property tuiApp;
    property tui;

    function init() {
        this.todos = ["Learn BoxLang", "Build TUI", "Profit"];
        this.completed = [true, false, false];
        this.selected = 1;
        this.inputMode = false;
        this.inputChars = [];
        this.statusMsg = "Welcome to Fluent Todo!";
        
        this.tuiApp = createObject("rust", "tui.App");
        this.tui = createObject("rust", "tui.TUI");
        
        return this;
    }

    function countCompleted() {
        count = 0;
        for (i = 1; i <= len(this.completed); i = i + 1) {
            if (this.completed[i]) {
                count = count + 1;
            }
        }
        return count;
    }

    function render() {
        total = len(this.todos);
        done = this.countCompleted();

        // 1. Header
        header = createObject("rust", "tui.Text")
            .text(" MatchBox Fluent Todo ")
            .color("cyan")
            .bold(true);

        // 2. Main List
        list = createObject("rust", "tui.List")
            .selected(this.selected - 1);
        
        for (i = 1; i <= total; i = i + 1) {
            statusStr = " [ ] ";
            if (this.completed[i]) {
                statusStr = " [x] ";
            }
            list.addItem(statusStr & this.todos[i]);
        }

        listBox = createObject("rust", "tui.Block")
            .title("Tasks")
            .border("rounded")
            .setWidget(list);

        // 3. Sidebar (Progress)
        progressLabel = createObject("rust", "tui.Text").text("Progress: " & done & "/" & total);
        bar = createObject("rust", "tui.ProgressBar")
            .completed(done)
            .total(total);

        sidebarContent = createObject("rust", "tui.VBox")
            .add(progressLabel)
            .add(bar)
            .add(createObject("rust", "tui.Text").text("").text(" Tips:").bold(true))
            .add(createObject("rust", "tui.Text").text(" 'a' to add"))
            .add(createObject("rust", "tui.Text").text(" 'd' to delete"))
            .add(createObject("rust", "tui.Text").text(" 'space' to toggle"))
            .add(createObject("rust", "tui.Text").text(" 'q' to quit"));

        sidebarBox = createObject("rust", "tui.Block")
            .title("Status")
            .border("rounded")
            .setWidget(sidebarContent);

        // 4. Content Area (HBox)
        content = createObject("rust", "tui.HBox")
            .add(listBox)
            .add(sidebarBox);

        // 5. Status Bar
        statusText = createObject("rust", "tui.Text")
            .text(" Status: " & this.statusMsg)
            .color("yellow");

        // 6. Root Layout
        root = createObject("rust", "tui.VBox")
            .add(header)
            .add(content)
            .add(statusText);

        if (this.inputMode) {
            inputVal = "";
            for (ci = 1; ci <= len(this.inputChars); ci = ci + 1) {
                inputVal = inputVal & this.inputChars[ci];
            }
            
            inputWidget = createObject("rust", "tui.Input")
                .prompt(" New Todo: ")
                .value(inputVal)
                .placeholder("Type and press Enter...");
            
            inputBox = createObject("rust", "tui.Block")
                .title("Input")
                .border("double")
                .setWidget(inputWidget);

            root.add(inputBox);
        }

        // Build and register
        this.tui.begin_frame();
        this.tui.clear_widgets();
        // Request a bit more height if input mode is on
        h = this.inputMode ? 24 : 20;
        this.tui.render_widget(root.build(), 0, 0, 60, h);
        this.tui.end_frame();
    }

    function run() {
        this.tui.init();
        
        try {
            this.render();
            
            while (!this.tuiApp.is_quit()) {
                event = this.tui.poll_event(10);
                if (!isNull(event)) {
                    if (event.type == "key") {
                        this.handleKey(event.key);
                    }
                }
                
                if (this.tui.is_dirty()) {
                    this.render();
                }
                sleep(10);
            }
        } finally {
            this.tui.shutdown();
        }
    }

    function handleKey(key) {
        if (this.inputMode) {
            if (key == "Enter") {
                newTodoText = "";
                for (ki = 1; ki <= len(this.inputChars); ki = ki + 1) {
                    newTodoText = newTodoText & this.inputChars[ki];
                }
                if (len(newTodoText) > 0) {
                    arrayAppend(this.todos, newTodoText);
                    arrayAppend(this.completed, false);
                    this.statusMsg = "Added: " & newTodoText;
                }
                this.inputMode = false;
                this.inputChars = [];
                this.tui.set_dirty();
            } else if (key == "Escape") {
                this.inputMode = false;
                this.inputChars = [];
                this.tui.set_dirty();
            } else if (key == "Backspace") {
                if (len(this.inputChars) > 0) {
                    arrayPop(this.inputChars);
                    this.tui.set_dirty();
                }
            } else if (len(key) == 1) {
                arrayAppend(this.inputChars, key);
                this.tui.set_dirty();
            }
        } else {
            if (key == "q" || key == "Ctrl+c") {
                this.tuiApp.stop();
            } else if (key == "a") {
                this.inputMode = true;
                this.statusMsg = "Adding new task...";
                this.tui.set_dirty();
            } else if (key == "d") {
                if (len(this.todos) > 0) {
                    removed = this.todos[this.selected];
                    arrayDeleteAt(this.todos, this.selected);
                    arrayDeleteAt(this.completed, this.selected);
                    if (this.selected > len(this.todos)) {
                        this.selected = max(1, len(this.todos));
                    }
                    this.statusMsg = "Deleted: " & removed;
                    this.tui.set_dirty();
                }
            } else if (key == " ") {
                if (len(this.completed) >= this.selected) {
                    this.completed[this.selected] = !this.completed[this.selected];
                    this.statusMsg = "Toggled task status";
                    this.tui.set_dirty();
                }
            } else if (key == "Up") {
                if (this.selected > 1) {
                    this.selected = this.selected - 1;
                    this.tui.set_dirty();
                }
            } else if (key == "Down") {
                if (this.selected < len(this.todos)) {
                    this.selected = this.selected + 1;
                    this.tui.set_dirty();
                }
            }
        }
    }
}

app = new App().init();
app.run();
